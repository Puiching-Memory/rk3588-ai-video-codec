@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

set_and_check(RKVC_INCLUDE_DIR "@PACKAGE_CMAKE_INSTALL_INCLUDEDIR@")
set_and_check(RKVC_LIB_DIR     "@PACKAGE_CMAKE_INSTALL_LIBDIR@")

if(NOT TARGET rkvc::rkvc)
    if(EXISTS "${RKVC_LIB_DIR}/${CMAKE_SHARED_LIBRARY_PREFIX}rkvc${CMAKE_SHARED_LIBRARY_SUFFIX}")
        add_library(rkvc::rkvc SHARED IMPORTED)
        set_target_properties(rkvc::rkvc PROPERTIES
            IMPORTED_LOCATION "${RKVC_LIB_DIR}/${CMAKE_SHARED_LIBRARY_PREFIX}rkvc${CMAKE_SHARED_LIBRARY_SUFFIX}"
            INTERFACE_INCLUDE_DIRECTORIES "${RKVC_INCLUDE_DIR}"
        )
    else()
        add_library(rkvc::rkvc STATIC IMPORTED)
        set_target_properties(rkvc::rkvc PROPERTIES
            IMPORTED_LOCATION "${RKVC_LIB_DIR}/${CMAKE_STATIC_LIBRARY_PREFIX}rkvc${CMAKE_STATIC_LIBRARY_SUFFIX}"
            INTERFACE_INCLUDE_DIRECTORIES "${RKVC_INCLUDE_DIR}"
        )
    endif()
endif()

check_required_components(rkvc)
