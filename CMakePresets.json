{
    "version": 6,
    "cmakeMinimumRequired": { "major": 3, "minor": 16, "patch": 0 },
    "configurePresets": [
        {
            "name": "default",
            "displayName": "Default (Release)",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
                "FFMPEG_ROOT": "/usr/local/ffmpeg-rockchip"
            }
        },
        {
            "name": "debug",
            "displayName": "Debug",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build-debug",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
                "FFMPEG_ROOT": "/usr/local/ffmpeg-rockchip"
            }
        },
        {
            "name": "tidy",
            "displayName": "clang-tidy Check",
            "inherits": "debug",
            "cacheVariables": {
                "CMAKE_C_CLANG_TIDY": "clang-tidy;--header-filter=${sourceDir}/include/.*"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "default",
            "configurePreset": "default",
            "targets": ["rkvc_shared", "rkvc_static", "rkvc_bench"]
        },
        {
            "name": "tests",
            "configurePreset": "default",
            "targets": ["rkvc_tests"]
        },
        {
            "name": "docs",
            "configurePreset": "default",
            "targets": ["rkvc_docs"]
        }
    ]
}
