{
    "version": 3,
    "cmakeMinimumRequired": { "major": 3, "minor": 16, "patch": 0 },
    "configurePresets": [
        {
            "name": "default",
            "displayName": "Default (Release)",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
            }
        },
        {
            "name": "debug",
            "displayName": "Debug",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build-debug",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
            }
        },
        {
            "name": "tidy",
            "displayName": "clang-tidy Check",
            "inherits": "debug",
            "cacheVariables": {
                "CMAKE_C_CLANG_TIDY": "clang-tidy;--header-filter=${sourceDir}/include/.*"
            }
        },
        {
            "name": "tests",
            "displayName": "Unit Tests",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build-tests",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
                "RKVC_BUILD_SHARED": "OFF",
                "RKVC_BUILD_EXAMPLES": "OFF",
                "RKVC_BUILD_TOOLS": "OFF",
                "RKVC_BUILD_TESTS": "ON",
                "RKVC_INSTALL": "OFF"
            }
        },
        {
            "name": "asan",
            "displayName": "ASan + UBSan Tests",
            "inherits": "tests",
            "binaryDir": "${sourceDir}/build-asan",
            "cacheVariables": {
                "RKVC_ENABLE_ASAN": "ON",
                "RKVC_ENABLE_UBSAN": "ON"
            }
        },
        {
            "name": "coverage",
            "displayName": "Coverage Tests",
            "inherits": "tests",
            "binaryDir": "${sourceDir}/build-coverage",
            "cacheVariables": {
                "RKVC_ENABLE_COVERAGE": "ON"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "default",
            "configurePreset": "default",
            "targets": ["rkvc_shared", "rkvc_static", "rkvc_bench", "rkvc_encode", "rkvc_decode", "rkvc_info"]
        },
        {
            "name": "tests",
            "configurePreset": "tests",
            "targets": ["check"]
        },
        {
            "name": "asan",
            "configurePreset": "asan",
            "targets": ["check"]
        },
        {
            "name": "coverage",
            "configurePreset": "coverage",
            "targets": ["check"]
        },
        {
            "name": "docs",
            "configurePreset": "default",
            "targets": ["docs"]
        },
        {
            "name": "package",
            "configurePreset": "default",
            "targets": ["package"]
        }
    ],
    "testPresets": [
        {
            "name": "tests",
            "configurePreset": "tests",
            "output": {
                "outputOnFailure": true
            }
        },
        {
            "name": "asan",
            "configurePreset": "asan",
            "output": {
                "outputOnFailure": true
            }
        },
        {
            "name": "coverage",
            "configurePreset": "coverage",
            "output": {
                "outputOnFailure": true
            }
        }
    ]
}
